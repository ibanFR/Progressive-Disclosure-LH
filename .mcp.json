{
  "mcpServers": {
    "miro": {
      "type": "http",
      "url": "https://mcp.miro.com/"
    },
    "claude-code-docs": {
      "type": "http",
      "url": "https://code.claude.com/docs/mcp"
    },
    "youtube": {
      "command": "npx",
      "args": ["-y", "zubeid-youtube-mcp-server"],
      "env": {
        "YOUTUBE_API_KEY": "${YOUTUBE_API_TOKEN}"
      }
    }
  }
}
